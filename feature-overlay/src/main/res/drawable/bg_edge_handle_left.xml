<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base glass fill: extremely subtle -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="17dp" />
            <solid android:color="#400D0B16" />
        </shape>
    </item>

    <!-- Inner glow from top -->
    <item android:top="1dp" android:bottom="1dp" android:right="1dp" android:left="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="270"
                android:startColor="#10FFFFFF"
                android:endColor="#00000000"
                android:type="linear" />
            <solid android:color="#00000000" />
        </shape>
    </item>

    <!-- Hairline border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="17dp" />
            <stroke android:width="0.5dp" android:color="#18A8C8FF" />
            <solid android:color="#00000000" />
        </shape>
    </item>

</layer-list>
