<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base glass fill: very subtle warm-tinted dark -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#CC0D0B16" />
        </shape>
    </item>

    <!-- Top-edge inner glow: brighter at top, fading down -->
    <item android:top="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <gradient
                android:angle="270"
                android:startColor="#14D8C3F2"
                android:centerColor="#08A8C8FF"
                android:endColor="#00000000"
                android:type="linear" />
        </shape>
    </item>

    <!-- Hairline border: subtle blue-violet glow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke android:width="0.5dp" android:color="#22D8C3F2" />
            <solid android:color="#00000000" />
        </shape>
    </item>

    <!-- Top edge highlight: slightly brighter stroke on the upper edge -->
    <item android:bottom="0dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="270"
                android:startColor="#10FFFFFF"
                android:endColor="#00000000"
                android:type="linear" />
            <solid android:color="#00000000" />
        </shape>
    </item>

</layer-list>
